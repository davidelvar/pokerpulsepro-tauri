{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PokerPulsePro",
  "version": "1.2.2",
  "identifier": "com.pokerpulsepro.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PokerPulsePro",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost; media-src 'self' asset: https://asset.localhost; connect-src 'self' ipc: http://ipc.localhost https://api.github.com https://github.com"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/davidelvar/pokerpulsepro-tauri/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE4M0RGQUFENjYyMkRDREUKUldUZTNDSm1yZm85cUFpeUN5a3F1b29mSGNoeFBZbUc1bTN5S2pUcmVGYUpzQzFmd1QvZVkvRmsK"
    }
  },
  "bundle": {
    "active": true,
    "publisher": "pokerpulsepro.com",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp"
      },
      "wix": {}
    },
    "macOS": {
      "entitlements": null,
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "iOS": {
      "developmentTeam": null
    },
    "android": {
      "minSdkVersion": 24
    }
  }
}
